---
import "@/styles/globals.css";
import { ToastContainer } from "react-toastify";
// @ts-ignore
import { pwaInfo } from "virtual:pwa-info";

export interface Props {
    className?: string;
}

const { className } = Astro.props;

// Absolute URL to the social-share preview image (public/preview.png).
// Social scrapers require an absolute URL, so resolve it against Astro.site.
const ogImage = new URL(
    `${import.meta.env.BASE_URL.replace(/\/?$/, "/")}preview.png`,
    Astro.site,
).href;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"
        />
        <!-- Empty icon: keeps the tab blank (no branding yet) while stopping the
        browser's default /favicon.ico request, which otherwise trips Astro's
        base check. Replace with base-aware icon links once a Spoons icon
        exists, e.g. <link rel="icon" href={`${import.meta.env.BASE_URL}...`} />. -->
        <link rel="icon" href="data:," />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Oxygen:wght@300;400;700&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
            rel="stylesheet"
        />
        <meta name="generator" content={Astro.generator} />
        <!-- HTML Meta Tags -->
        <title>Spoons Hide and Seek — Tyne and Wear</title>
        <meta
            name="description"
            content="A Jet Lag-style hide and seek map for Tyne and Wear. Shows the game boundary, valid public-transport stops, and every area within 500 m of a stop where you can legally hide."
        />

        <!-- Open Graph Meta Tags -->
        <meta property="og:type" content="website" />
        <meta
            property="og:title"
            content="Spoons Hide and Seek — Tyne and Wear"
        />
        <meta
            property="og:description"
            content="A Jet Lag-style hide and seek map for Tyne and Wear. Shows the game boundary, valid public-transport stops, and every area within 500 m of a stop where you can legally hide."
        />
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:alt" content="Spoons Hide and Seek" />

        {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
    </head>
    <body class:list={[className, "dark"]}>
        <slot />
        <ToastContainer client:only />
        <script is:inline>
            // Block browser page pinch/zoom (iOS Safari ignores
            // user-scalable=no). Leaflet's own map zoom uses touch events, not
            // these iOS "gesture" events, so the map still zooms while the rest
            // of the UI cannot — this prevents the soft-lock where zooming the
            // page over a sidebar left no way to zoom back out.
            ["gesturestart", "gesturechange", "gestureend"].forEach((type) =>
                document.addEventListener(
                    type,
                    (event) => event.preventDefault(),
                    { passive: false },
                ),
            );
        </script>
    </body>
</html>
